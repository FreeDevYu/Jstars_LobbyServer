ASPNETCORE_ENVIRONMENT=Production

# PC에서 돌아가는 MySQL / Redis에 연결 (Docker Desktop)
ConnectionStrings__DBConnection=Server=host.docker.internal;Port=3306;Database=JStarsDB;Uid=root;Pwd=YOUR_PASSWORD;AllowPublicKeyRetrieval=True;
RedisConnection=host.docker.internal:6379,abortConnect=false

EmailSettings__SmtpServer=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__SenderName=Portfolio Game Server
EmailSettings__SenderEmail=your@gmail.com
EmailSettings__Password=YOUR_GMAIL_APP_PASSWORD
