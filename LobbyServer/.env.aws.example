ASPNETCORE_ENVIRONMENT=Production

# AWS RDS (same VPC as EC2)
ConnectionStrings__DBConnection="Server=YOUR_RDS_ENDPOINT;Port=3306;Database=JStarsDB;Uid=admin;Pwd=YOUR_RDS_PASSWORD;AllowPublicKeyRetrieval=True;"

# AWS ElastiCache Redis (same VPC as EC2)
# Cluster mode ON  -> clustercfg.xxx.cache.amazonaws.com:6379
# Cluster mode OFF -> primary endpoint xxx.cache.amazonaws.com:6379
RedisConnection=clustercfg.jstars-redis.xxxxx.apn2.cache.amazonaws.com:6379,abortConnect=false

EmailSettings__SmtpServer=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__SenderName=Portfolio Game Server
EmailSettings__SenderEmail=your@gmail.com
EmailSettings__Password=YOUR_GMAIL_APP_PASSWORD
