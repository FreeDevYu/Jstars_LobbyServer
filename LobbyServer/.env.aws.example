# AWS EC2 배포용 (.env.aws)
# ------------------------------------------------------------
# 1) copy .env.aws.example .env.aws
# 2) 아래 YOUR_* 값을 RDS / ElastiCache / Gmail 값으로 교체
# 3) EC2에 .env.aws를 두고 docker compose -f docker-compose.aws.yml up -d
#
# Deploy.bat은 소스만 업로드합니다. .env.aws는 EC2에 직접 두거나
# 최초 1회 scp로 복사하세요. (git / tar 업로드 대상 아님)
# ------------------------------------------------------------

ASPNETCORE_ENVIRONMENT=Production

# AWS RDS (EC2와 같은 VPC, SG에서 EC2 -> RDS 3306 허용)
ConnectionStrings__DBConnection="Server=YOUR_RDS_ENDPOINT.ap-northeast-2.rds.amazonaws.com;Port=3306;Database=JStarsDB;Uid=YOUR_RDS_USER;Pwd=YOUR_RDS_PASSWORD;AllowPublicKeyRetrieval=True;"

# AWS ElastiCache Redis (EC2와 같은 VPC, SG에서 EC2 -> Redis 6379 허용)
# Cluster mode ON  -> clustercfg.xxx.cache.amazonaws.com:6379
# Cluster mode OFF -> xxx.xxxxx.apn2.cache.amazonaws.com:6379
RedisConnection=clustercfg.YOUR_REDIS_CLUSTER.xxxxx.apn2.cache.amazonaws.com:6379,abortConnect=false

EmailSettings__SmtpServer=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__SenderName=Portfolio Game Server
EmailSettings__SenderEmail=your@gmail.com
EmailSettings__Password=YOUR_GMAIL_APP_PASSWORD
