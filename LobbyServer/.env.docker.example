# 로컬 Docker용 (.env.docker) — Start.bat / docker-compose.yml
# ------------------------------------------------------------
# 1) copy .env.docker.example .env.docker
# 2) YOUR_PASSWORD 등을 PC의 MySQL / Gmail 값으로 교체
# 3) PC에서 MySQL(3306), Redis(6379) 실행 후 docker compose up -d
#
# AWS 배포는 .env.aws.example 참고 (docker-compose.aws.yml)
# ------------------------------------------------------------

# Development: Swagger(/swagger) 활성화. Production이면 Swagger 비활성.
ASPNETCORE_ENVIRONMENT=Development

# PC에서 돌아가는 MySQL / Redis (Docker Desktop → host.docker.internal)
ConnectionStrings__DBConnection=Server=host.docker.internal;Port=3306;Database=JStarsDB;Uid=root;Pwd=YOUR_PASSWORD;AllowPublicKeyRetrieval=True;
RedisConnection=host.docker.internal:6379,abortConnect=false

EmailSettings__SmtpServer=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__SenderName=Portfolio Game Server
EmailSettings__SenderEmail=your@gmail.com
EmailSettings__Password=YOUR_GMAIL_APP_PASSWORD

# 로컬 모니터 (/monitor.html) — 비우면 API 키 없이 조회 가능
Monitoring__ApiKey=
